# === Trinity Guard 产研系统环境变量 ===

# Tushare 数据源
TUSHARE_TOKEN=your_tushare_token_here

# 共享 LiteLLM / One-API（由 shared-infra 提供，填写 master key 即可）
LITELLM_MASTER_KEY=sk-litellm-trinity
ONE_API_KEY=your_one_api_key_here

# 七牛云存储（产研数据持久化）
QINIU_ACCESS_KEY=your_qiniu_access_key
QINIU_SECRET_KEY=your_qiniu_secret_key
QINIU_BUCKET=trinity-proddev-data
QINIU_DOMAIN=your_bucket_domain.qiniucdn.com

# 服务端口（容器内部端口，与 docker-compose.yml 保持一致）
PORT=8001
